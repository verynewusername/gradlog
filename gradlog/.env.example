# Server Configuration
PORT=8080
HOST=0.0.0.0

# Database Configuration (overridden by docker-compose for container networking)
DATABASE_URL=postgres://gradlog:gradlog@localhost:5432/gradlog?sslmode=disable

# Google OAuth Configuration (optional - leave empty to disable OAuth login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Artifact Storage Configuration
ARTIFACT_STORAGE_PATH=/data/artifacts
# Maximum chunk size in bytes (default: 50MB)
ARTIFACT_CHUNK_SIZE=52428800
# Maximum single file size in bytes (0 = unlimited)
ARTIFACT_MAX_FILE_SIZE=0

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:8080

# Production example for gradlog.efesirin.com:
# GOOGLE_REDIRECT_URL=https://gradlog.example.com/api/v1/auth/google/callback
# FRONTEND_URL=https://gradlog.example.com
